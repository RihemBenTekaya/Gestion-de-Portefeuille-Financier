@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div>
                <strong>Green Portfolio</strong>
                <span class="text-muted ms-2 d-none d-md-inline">Blazor + EF Core investment tracker</span>
            </div>
            <a href="/transactions/new" class="btn btn-sm btn-success">New Transaction</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
