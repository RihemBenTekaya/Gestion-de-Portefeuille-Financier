@using DashboardData.Models

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Asset</th>
                <th>Type</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Value</th>
                <th>Gain / Loss</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (AssetItems == null || !AssetItems.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">No assets found.</td>
                </tr>
            }
            else
            {
                @foreach (var asset in AssetItems)
                {
                    var stat = GetStat(asset.Id);
                    <tr>
                        <td>
                            <div class="fw-semibold">@asset.Name</div>
                            <div class="text-muted small">@asset.Symbol</div>
                        </td>
                        <td><span class="badge text-bg-success">@asset.Type</span></td>
                        <td>@FormatMoney(asset.CurrentPrice)</td>
                        <td>@(stat?.CurrentQuantity.ToString("0.####") ?? "0")</td>
                        <td>@FormatMoney(stat?.CurrentValue ?? 0)</td>
                        <td class="@(stat?.GainLoss >= 0 ? "text-success" : "text-danger")">
                            @FormatMoney(stat?.GainLoss ?? 0)
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2 flex-wrap">
                            <a href="/assets/edit/@asset.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => TriggerDelete(asset.Id)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<Asset> AssetItems { get; set; } = new();

    [Parameter]
    public List<AssetPerformanceStat> PerformanceStats { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnDeleteClicked { get; set; }

    private AssetPerformanceStat GetStat(int assetId)
    {
        return PerformanceStats.FirstOrDefault(s => s.AssetId == assetId);
    }

    private async Task TriggerDelete(int id)
    {
        await OnDeleteClicked.InvokeAsync(id);
    }

    private string FormatMoney(decimal value)
    {
        return $"{value:0.00} TND";
    }
}
