@using DashboardData.Models

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Label</th>
                <th>Amount</th>
                <th>Start Date</th>
                <th>Notes</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Budgets == null || !Budgets.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">No budgets found.</td>
                </tr>
            }
            else
            {
                @foreach (var budget in Budgets)
                {
                    <tr>
                        <td class="fw-semibold">@budget.Label</td>
                        <td>@FormatMoney(budget.Amount)</td>
                        <td>@budget.StartDate.ToString("yyyy-MM-dd")</td>
                        <td class="text-muted">@budget.Notes</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2 flex-wrap">
                            <a href="/budgets/edit/@budget.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => TriggerDelete(budget.Id)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<InvestmentBudget> Budgets { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnDeleteClicked { get; set; }

    private async Task TriggerDelete(int id)
    {
        await OnDeleteClicked.InvokeAsync(id);
    }

    private string FormatMoney(decimal value)
    {
        return $"{value:0.00} TND";
    }
}
