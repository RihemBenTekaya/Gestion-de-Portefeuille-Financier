@using DashboardData.Models

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Date</th>
                <th>Asset</th>
                <th>Operation</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Fees</th>
                <th>Total</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Transactions == null || !Transactions.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">No transactions found.</td>
                </tr>
            }
            else
            {
                @foreach (var transaction in Transactions)
                {
                    <tr>
                        <td>@transaction.OperationDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="fw-semibold">@transaction.Asset?.Symbol</div>
                            <div class="text-muted small">@transaction.Asset?.Name</div>
                        </td>
                        <td>
                            <span class="badge @(transaction.OperationType == "Buy" ? "text-bg-success" : "text-bg-danger")">
                                @transaction.OperationType
                            </span>
                        </td>
                        <td>@transaction.Quantity.ToString("0.####")</td>
                        <td>@FormatMoney(transaction.UnitPrice)</td>
                        <td>@FormatMoney(transaction.Fees)</td>
                        <td>@FormatMoney(transaction.GrossAmount)</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2 flex-wrap">
                            <a href="/transactions/edit/@transaction.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => TriggerDelete(transaction.Id)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<PortfolioTransaction> Transactions { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnDeleteClicked { get; set; }

    private async Task TriggerDelete(int id)
    {
        await OnDeleteClicked.InvokeAsync(id);
    }

    private string FormatMoney(decimal value)
    {
        return $"{value:0.00} TND";
    }
}
