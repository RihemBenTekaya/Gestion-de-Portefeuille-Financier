@page "/budgets/new"
@page "/budgets/edit/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@using DashboardData.Models
@using DashboardData.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IPortfolioService PortfolioService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(Id.HasValue ? "Edit Budget" : "New Budget")</PageTitle>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="mb-1">@(Id.HasValue ? "Edit Budget" : "Create Budget")</h1>
        <p class="text-muted mb-0">Budget lines are summed to calculate the investment envelope.</p>
    </div>
    <a href="/budgets" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Budgets</a>
</div>

@if (NotFound)
{
    <div class="alert alert-warning">
        The budget was not found. Return to the budget list and choose an existing row.
    </div>
}
else if (CurrentBudget == null)
{
    <p><em>Loading form...</em></p>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="CurrentBudget" OnValidSubmit="HandleValidSubmit" FormName="BudgetEditForm">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <input type="hidden" name="CurrentBudget.Id" value="@CurrentBudget.Id" />

                <div class="row g-3">
                    <div class="col-md-7">
                        <label class="form-label">Label</label>
                        <InputText @bind-Value="CurrentBudget.Label" class="form-control" placeholder="Example: Main Budget" />
                        <ValidationMessage For="@(() => CurrentBudget.Label)" class="text-danger" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Amount</label>
                        <InputNumber @bind-Value="CurrentBudget.Amount" class="form-control" />
                        <ValidationMessage For="@(() => CurrentBudget.Amount)" class="text-danger" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Start date</label>
                        <InputDate @bind-Value="CurrentBudget.StartDate" class="form-control" />
                        <ValidationMessage For="@(() => CurrentBudget.StartDate)" class="text-danger" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label">Notes</label>
                        <InputText @bind-Value="CurrentBudget.Notes" class="form-control" placeholder="Optional note" />
                        <ValidationMessage For="@(() => CurrentBudget.Notes)" class="text-danger" />
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-success"><i class="bi bi-check2-circle"></i> Save Budget</button>
                    <a href="/budgets" class="btn btn-secondary">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    [SupplyParameterFromForm]
    private InvestmentBudget CurrentBudget { get; set; }
    private bool NotFound;

    protected override async Task OnInitializedAsync()
    {
        // Get current user ID first
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (Id.HasValue && CurrentBudget == null)
        {
            CurrentBudget = await PortfolioService.GetBudgetByIdAsync(Id.Value);
            if (CurrentBudget == null)
            {
                NotFound = true;
                return;
            }
        }
        else if (CurrentBudget == null)
        {
            CurrentBudget = new InvestmentBudget
            {
                Label = "Investment Budget",
                Amount = 1000,
                StartDate = DateTime.Today,
                UserId = userId ?? "" // Set UserId immediately
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        // Get current user ID
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            
            if (Id.HasValue)
            {
                CurrentBudget.Id = Id.Value;
                CurrentBudget.UserId = userId; // Ensure UserId is set
                await PortfolioService.UpdateBudgetAsync(CurrentBudget);
            }
            else
            {
                CurrentBudget.UserId = userId; // Set UserId for new budget
                await PortfolioService.AddBudgetAsync(CurrentBudget);
            }

            NavigationManager.NavigateTo("/budgets");
        }
    }
}
